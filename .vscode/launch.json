{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run scripts/dist_clean.py",
            "type": "debugpy", 
            "request": "launch",
            "program": "scripts/dist_clean.py",
            "args": [ "-f" ],
            "console": "integratedTerminal",
            "consoleName": "scripts/dist_clean Debug Console",
            "logToFile": true,
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        },        {
            "name": "Run scripts/build_dist.py --clean",
            "type": "debugpy", 
            "request": "launch",
            "program": "scripts/build_dist.py",
            "args": [
                "--clean"
            ],
            "console": "integratedTerminal",
            "consoleName": "scripts/build_dist Debug Console",
            "logToFile": true,
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        },
        {
            "name": "DrawRunes with Arguments",
            "type": "debugpy", 
            "request": "launch",
            "console": "integratedTerminal",
            "program": "DrawRunes/main.py",
            "consoleName": "DrawRunes Debug Console",
            "args": "${command:pickArgs}",
            "logToFile": true,
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "DrawRunes: set Arguments",
            "type": "debugpy", 
            "request": "launch",
            "console": "integratedTerminal",
            "program": "DrawRunes/main.py",
            "consoleName": "DrawRunes Debug Console",
            "args": "-n 7 -o output.png",
            "logToFile": true,
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "Run DrawRunes` without Arguments",
            "type": "debugpy", 
            "request": "launch",
            "program": "DrawRunes/main.py",
            "console": "integratedTerminal",
            "consoleName": "DrawRunes Debug Console",
            "logToFile": true,
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
    ]
}   